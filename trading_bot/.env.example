# AI Trading Bot VPS Configuration
# Copy this file to .env and fill in your values

# MT5 Connection
MT5_LOGIN=0
MT5_PASSWORD=your_password_here
MT5_SERVER=ICMarkets-Demo

# DeepSeek AI
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Analysis symbols
SYMBOLS=EURUSD,GBPUSD,XAUUSD

# Logging
LOG_LEVEL=INFO

# Simulation Mode (false = live)
SIMULATION_MODE=false

# Execution
EXECUTION_ENABLED=false
DEFAULT_TIMEFRAME_EXEC=H1

# Risk Management
MAX_RISK_PERCENT=2.0
MAX_DAILY_LOSS_PERCENT=5.0
MAX_CONSECUTIVE_LOSSES=3
MAX_SPREAD_MULTIPLIER=2.0
MAX_ATR_PERCENT=2.0
AI_MIN_CONFIDENCE=70

# Continuous run mode (VPS 24/7)
CONTINUOUS_MODE=true
ANALYSIS_INTERVAL_MINUTES=1

# Multi-account support (JSON array)
ACCOUNTS_JSON=[]

# Simulation defaults
SIMULATION_MODE=false
SIMULATION_INITIAL_BALANCE=10000.0